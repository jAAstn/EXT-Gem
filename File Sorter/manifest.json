
{
  "manifest_version": 2,
  "name": "Download Ordner Ersteller",
  "version": "4.4",
  "description": "Automatically organizes downloaded images from selected domains.",
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "permissions": [
    "downloads",
    "downloads.shelf",
    "downloads.ui",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/128.png"
  },
  "icons": {
    "128": "icons/128.png"
  }
}
